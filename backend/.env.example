DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/restaurant_db
JWT_SECRET_KEY=change-me-to-a-random-32-char-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
CANCELLATION_CUTOFF_HOURS=2
MAX_ACTIVE_BOOKINGS_PER_USER=3
OPERATING_HOURS_START=11
OPERATING_HOURS_END=22

# Email (SMTP) — leave SMTP_HOST empty to disable (logs instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
